{"version":3,"kind":"Notebook","sha256":"199fc5a896c52fb64bf86de61bd63e76798381211724b9d51b78bf8a71c06eee","slug":"jupyter-notebooks","location":"/jupyter-notebooks.ipynb","dependencies":[],"frontmatter":{"title":"Jupyter Notebooks","content_includes_title":false,"kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"authors":[{"nameParsed":{"literal":"Rubelito Abella","given":"Rubelito","family":"Abella"},"name":"Rubelito Abella","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/HowDoIGitHelp/Python-Fundamentals","source_url":"https://github.com/HowDoIGitHelp/Python-Fundamentals/blob/main/jupyter-notebooks.ipynb","edit_url":"https://github.com/HowDoIGitHelp/Python-Fundamentals/edit/main/jupyter-notebooks.ipynb","thumbnail":"/build/anaconda_navigator-f2fe675e9ab38cd6bdc3669b289e6c99.png","thumbnailOptimized":"/build/anaconda_navigator-f2fe675e9ab38cd6bdc3669b289e6c99.webp","exports":[{"format":"ipynb","filename":"jupyter-notebooks.ipynb","url":"/build/jupyter-notebooks-c5cb245eb9e4fbc8ca91fbd12645ca0e.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"Throughout this training course, you will be using jupyter to write python code, perform data analysis, present results, create visualization, and more.\nJupyter notebooks offer data scientists a way to build interactive environments that combine code, documentation, and output. In fact the lecture notes that you will be reading are written in jupyter notebooks.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"lmbJCFEFlW"}],"key":"iRsJiZApjT"},{"type":"heading","depth":2,"position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"Launching Jupyter notebook","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"xXB7HSQUpS"}],"identifier":"launching-jupyter-notebook","label":"Launching Jupyter notebook","html_id":"launching-jupyter-notebook","implicit":true,"key":"V6FpMPInZ2"},{"type":"paragraph","position":{"start":{"line":8,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"If you installed python through the anaconda distribution, you should be able to launch Jupyter Notebook or Jupyter Lab in Anaconda Navigator.\nYou can also launch them through Anacaonda Prompt. Just run the commands ","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"bYy4D0mDDF"},{"type":"inlineCode","value":"jupyter lab","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"JhiRLuzNlS"},{"type":"text","value":" or ","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"NvASnZsSbO"},{"type":"inlineCode","value":"jupyter notebook","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"OsklTSBmh1"},{"type":"text","value":". You can select either jupyter lab or jupyter notebook.","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"ETKgzGj8XG"}],"key":"di9Nt79hfB"},{"type":"image","url":"/build/anaconda_navigator-f2fe675e9ab38cd6bdc3669b289e6c99.png","alt":"anaconda navigator","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"xbvtRCrjdK","urlSource":"images/anaconda_navigator.png","urlOptimized":"/build/anaconda_navigator-f2fe675e9ab38cd6bdc3669b289e6c99.webp"},{"type":"paragraph","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"It’s up to you on which environment you prefer. Both of them will run through your browser.","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"CA5byPa6NI"}],"key":"OkjNZX3nwA"},{"type":"heading","depth":2,"position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"Creating notebooks","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"dhJDPqEmwW"}],"identifier":"creating-notebooks","label":"Creating notebooks","html_id":"creating-notebooks","implicit":true,"key":"WX9gTO02Zk"},{"type":"paragraph","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"Once you’ve launched jupyter through either lab/notebook, you should be able to see a file explorer page/tab.","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"Me0Li4sgWU"}],"key":"WW2otoThrE"},{"type":"image","url":"/build/jupyter_notebook_exp-642d4a1af838a7489994769197a06749.png","alt":"jupyter notebook explorer.png","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"s4Y42d0qCn","urlSource":"images/jupyter_notebook_explorer.png","urlOptimized":"/build/jupyter_notebook_exp-642d4a1af838a7489994769197a06749.webp"},{"type":"image","url":"/build/jupyter_lab_explorer-8e71a182c347aca5834adf8f81250cc5.png","alt":"jupyter lab explorer.png","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"uSmXS1bIvB","urlSource":"images/jupyter_lab_explorer.png","urlOptimized":"/build/jupyter_lab_explorer-8e71a182c347aca5834adf8f81250cc5.webp"},{"type":"paragraph","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"text","value":"The file explorer shows the directory where you installed anaconda or where your ran the command. From here you can navigate to the folder of your choice and create a new notebook. When creating a notebook, jupyter might ask you to select a kernel. Choose Python3 (ipykernel).","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"VibY9mxR9O"}],"key":"UF1TGLRgOh"},{"type":"heading","depth":2,"position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"children":[{"type":"text","value":"Interacting with python through Jupyter Notebooks","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"B6SlQ98g1f"}],"identifier":"interacting-with-python-through-jupyter-notebooks","label":"Interacting with python through Jupyter Notebooks","html_id":"interacting-with-python-through-jupyter-notebooks","implicit":true,"key":"XLrOA5x5Rf"},{"type":"paragraph","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"children":[{"type":"text","value":"Jupyter notebooks are composed of cells. Cells can either contain code, markdown, or raw text. With an new notebook you start with one code cell","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"JtU0jI9BZQ"}],"key":"uQZ0olVMXi"},{"type":"image","url":"/build/jupyter_notebook_emp-2f02fa87c7c3cb423152df2729fd0ed8.png","alt":"jupyter notebook empty.png","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"key":"fNKAjJC1mv","urlSource":"images/jupyter_notebook_empty.png","urlOptimized":"/build/jupyter_notebook_emp-2f02fa87c7c3cb423152df2729fd0ed8.webp"},{"type":"paragraph","position":{"start":{"line":31,"column":1},"end":{"line":32,"column":1}},"children":[{"type":"text","value":"Click on the cell to edit it. Since this is a code cell, it is expecting python code.\nWe can write a python expression here","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"mv5uH3YYIY"}],"key":"OfHH5wRE5n"},{"type":"image","url":"/build/jupyter_code_cell-eb08ddbfb8c8954d14fd1e11d5f214f5.png","alt":"jupyter code cell.png","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"N73wURY8Ge","urlSource":"images/jupyter_code_cell.png","urlOptimized":"/build/jupyter_code_cell-eb08ddbfb8c8954d14fd1e11d5f214f5.webp"},{"type":"paragraph","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"text","value":"While the cell is selected, you can press Shift+Enter to run the cell (note how this also automatically adds an empty code cell in the bottom). When a code cell is run the code inside it will be executed. It will also check the last line of the cell and try to print its evaluation.","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"key":"nWcHp44TRY"}],"key":"gTeTl9vgmq"},{"type":"image","url":"/build/jupyter_outputs-2b8296124d61e62efb3d4ed3db2bd314.png","alt":"jupyter outputs.png","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"w7SPwKpaqQ","urlSource":"images/jupyter_outputs.png","urlOptimized":"/build/jupyter_outputs-2b8296124d61e62efb3d4ed3db2bd314.webp"},{"type":"paragraph","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"children":[{"type":"text","value":"In the example above we have created a new cell and added two lines of expression. Notice how in the second cell, there is only one output. As said before, the cells output will automatically display the evaluation of the last line of code.","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"L7nvechCRy"}],"key":"RuRQ4iyewg"},{"type":"paragraph","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"children":[{"type":"text","value":"You can also force jupyter to display other things by explicitly calling python’s ","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"LBiKEJP0Hl"},{"type":"inlineCode","value":"print()","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"wbVfpSRZyG"},{"type":"text","value":" function","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"sQvtozV5PF"}],"key":"d9J2AarSyG"},{"type":"image","url":"/build/jupyter_cells_printi-ef815c9cb1945a0a4f601621a1b412b7.png","alt":"jupyter cells printing.png","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"Qs0NRJkuiW","urlSource":"images/jupyter_cells_printing.png","urlOptimized":"/build/jupyter_cells_printi-ef815c9cb1945a0a4f601621a1b412b7.webp"},{"type":"paragraph","position":{"start":{"line":46,"column":1},"end":{"line":46,"column":1}},"children":[{"type":"text","value":"If you want to change the cell type of a cell, you can select the desired type in the dropdown found in the tool bar. Other than code cells, you can choose between raw text cells, and markdown cells. Raw text cells will simply render the text placed inside it, while markdown cells will render the text with markdown formatting. Raw text cells and markdown cells are not executed by jupyter. Use these cells to add narratives or documentation.","position":{"start":{"line":46,"column":1},"end":{"line":46,"column":1}},"key":"yIxWvg7GlT"}],"key":"fHSHFzbCWL"},{"type":"paragraph","position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"children":[{"type":"text","value":"For more detailed tutorials, tips, and tricks on how to use Jupyter you check the following external resource:","position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"key":"IA8lUGXDx6"}],"key":"U6xMEuxzgj"},{"type":"paragraph","position":{"start":{"line":50,"column":1},"end":{"line":50,"column":1}},"children":[{"type":"link","url":"https://www.dataquest.io/blog/jupyter-notebook-tutorial/","position":{"start":{"line":50,"column":1},"end":{"line":50,"column":1}},"children":[{"type":"text","value":"How to Use Jupyter Notebook: A Beginner’s Tutorial","position":{"start":{"line":50,"column":1},"end":{"line":50,"column":1}},"key":"xIG6YDq1Cg"}],"urlSource":"https://www.dataquest.io/blog/jupyter-notebook-tutorial/","key":"qBlWEq3MpV"}],"key":"USOOCPot6o"}],"key":"byNIGeKXVG"}],"key":"Pj3YoUxxwo"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Installing Python","url":"/installing-python","group":"Python Programming Fundamentals"},"next":{"title":"Expressions","url":"/expressions","group":"Python Programming Fundamentals"}}},"domain":"http://localhost:300